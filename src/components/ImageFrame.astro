---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  ratio?: '16/9' | '4/3' | '1/1' | '3/4' | '21/9' | '5/3';
  mode?: 'cover' | 'contain';
  focal?: string;
  eager?: boolean;
  widths?: number[];
  sizes?: string;
  class?: string;
}

const {
  src,
  alt,
  ratio = '4/3',
  mode = 'cover',
  focal = 'center',
  eager = false,
  widths = [400, 800, 1200],
  sizes = '100vw',
  class: className,
} = Astro.props;
---

<div class:list={['image-frame', `image-frame--${mode}`, className]} style={`aspect-ratio: ${ratio};`}>
  <Picture
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    formats={['avif', 'webp']}
    fallbackFormat="webp"
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding={eager ? 'sync' : 'async'}
    style={mode === 'cover' ? `object-position: ${focal};` : undefined}
  />
</div>

<style>
  .image-frame {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .image-frame :global(img) {
    width: 100%;
    height: 100%;
  }

  .image-frame--cover :global(img) {
    object-fit: cover;
  }

  .image-frame--contain {
    background: var(--brand-cream);
    padding: 0.85rem;
  }

  .image-frame--contain :global(img) {
    object-fit: contain;
  }
</style>
