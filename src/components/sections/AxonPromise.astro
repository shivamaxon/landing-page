---
const steps = [
  { title: 'Design', desc: 'Balinese tropical architecture, planned for the site.' },
  { title: 'Approvals', desc: 'Clear freehold title, development-ready infrastructure.' },
  { title: 'Leasing', desc: 'Support once you choose to lease your villa.' },
  { title: 'Resale Support', desc: 'We stay involved well past handover.' },
];

---

<section class="section section--cream">
  <div class="section-inner">
    <p class="eyebrow reveal">The Axon Promise</p>
    <h2 class="section-title reveal">One Company. One Focus. End to End.</h2>
    <p class="section-body reveal reveal-delay-1">
      We build the best second homes across India — nothing else — for
      customers across <strong>61 cities in 12 states</strong>. We stay
      invested as long as you are.
    </p>

    <div class="process-grid">
      {
        steps.map((s, i) => (
          <div class={`process-step reveal reveal-delay-${Math.min(i + 1, 3)}`}>
            <div class="process-step__num">{String(i + 1).padStart(2, '0')}</div>
            <div class="process-step__title">{s.title}</div>
            <div class="process-step__desc">{s.desc}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
