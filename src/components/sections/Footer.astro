---
import Logo from '../Logo.astro';
---

<footer class="site-footer">
  <div class="site-footer__logo">
    <Logo width={140} variant="light" />
  </div>

  <p>
    The Riviera by Axon Developers — 20 river-touching villa plots on the Gad
    River, Konkan, Sindhudurg.
  </p>

  <p>
    All infrastructure timelines referenced are as sanctioned and publicly
    announced, and are subject to change. Please verify all details
    independently before making any purchase decision.
  </p>

  <p class="site-footer__policy">
    Disclaimer &amp; Privacy Policy: All the content, images and logos of
    partners presented here are solely representative in nature…
    <a href="/privacy-policy">Read More</a>
  </p>

  <p>&copy; {new Date().getFullYear()} Axon Developers. All rights reserved.</p>
</footer>

<style>
  .site-footer__policy a {
    color: inherit;
    text-decoration: underline;
    font-weight: 700;
  }
</style>
