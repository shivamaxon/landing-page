---
import { Picture } from 'astro:assets';
import hero1 from '../../assets/images/Hero1.png';
import hero2 from '../../assets/images/Hero2.png';
import hero3 from '../../assets/images/Hero3.png';

const heroImages = [hero1, hero2, hero3];
---

<section class="hero" id="home">
  <div class="hero__images">
    {
      heroImages.map((img, i) => (
        <Picture
          src={img}
          alt="The Riviera — riverfront villa plots on the Gad River in Vagade, Sindhudurg"
          widths={[400, 800, 1200, 1920]}
          sizes="100vw"
          formats={['avif', 'webp']}
          fallbackFormat="webp"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding={i === 0 ? 'sync' : 'async'}
          class:list={['hero__image', { 'is-active': i === 0 }]}
          data-hero-slide={i}
        />
      ))
    }
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">The Riviera</h1>
    <h2 class="hero__tagline">
      Riverfront Villa Plots in Sindhudurg — India's Most Exclusive Riverside
      Living
    </h2>
    <div class="hero__actions">
      <button type="button" class="btn btn-primary" data-gate-trigger data-intent="enquiry">
        Enquire Now
      </button>
      <a href="#overview" class="btn btn-outline">
        Discover More
      </a>
    </div>
  </div>
</section>

<script>
  const ROTATE_INTERVAL_MS = 4500;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const slides = Array.from(document.querySelectorAll('[data-hero-slide]'));
  if (!reducedMotion && slides.length > 1) {
    let active = 0;
    window.setInterval(() => {
      const next = (active + 1) % slides.length;
      slides[active].classList.remove('is-active');
      slides[next].classList.add('is-active');
      active = next;
    }, ROTATE_INTERVAL_MS);
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero__images {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .hero__image.is-active {
    opacity: 1;
    animation: hero-zoom 20s ease-out forwards;
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__image {
      transition: none;
      animation: none;
    }

    .hero__image:first-child {
      opacity: 1;
    }

    .hero__image:not(:first-child) {
      display: none;
    }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(4, 20, 18, 0.08) 0%,
      rgba(4, 20, 18, 0.22) 50%,
      rgba(4, 20, 18, 0.78) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 2rem 1.5rem 4.5rem;
    text-align: center;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: clamp(2.5rem, 10vw, 4.5rem);
    color: var(--text-on-dark);
    line-height: 1.05;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
  }

  .hero__tagline {
    margin: 0.75rem 0 0;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(1rem, 4vw, 1.25rem);
    color: var(--text-on-dark);
  }

  .hero__actions {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .hero__actions .btn {
    width: 100%;
    max-width: 260px;
    color: var(--text-on-dark);
  }

  @media (min-width: 480px) {
    .hero__actions {
      flex-direction: row;
      justify-content: center;
    }

    .hero__actions .btn {
      width: auto;
    }
  }
</style>
