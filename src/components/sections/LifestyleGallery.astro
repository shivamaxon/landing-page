---
import ImageFrame from '../ImageFrame.astro';
import { galleryImages } from '../../data/gallery-images.js';
---

<section class="section section--cream-cool" id="gallery">
  <div class="section-inner">
    <p class="eyebrow reveal">The Lifestyle</p>
    <h2 class="section-title reveal">Everyday Life, Riverfront</h2>
  </div>
  <div class="gallery-grid gallery-grid--capped">
    {
      galleryImages.map((img, i) => (
        <button
          type="button"
          data-lightbox-trigger
          data-lightbox-index={i}
          aria-label={`View larger: ${img.alt}`}
          class={`reveal reveal-delay-${Math.min((i % 3) + 1, 3)}`}
        >
          <ImageFrame src={img.src} alt={img.alt} ratio="1/1" focal={img.focal} />
        </button>
      ))
    }
  </div>
</section>

<style>
  /* Marketing flagged gallery tiles as too large on desktop — cap the
     grid's rendered width instead of letting it stretch full viewport. */
  @media (min-width: 900px) {
    .gallery-grid--capped {
      max-width: 720px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
