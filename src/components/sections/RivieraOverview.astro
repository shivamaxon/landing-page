---
// Folds the previous standalone "Only 1% of India's land is riverfront"
// scarcity statement into this section's lead-in (that stat is USP #1 in
// docs/brand-guidelines.md) — the marketing-supplied flow for this pass
// lists this as the second section overall with no separate scarcity
// section, so the two are merged rather than dropping the stat entirely.
//
// Design-review pass: the scarcity line and the 20-plots line used to be
// two same-weight headlines stacked back to back, competing for attention.
// Now the scarcity line is a small lead-in statement and the 20-plots line
// is the section's one dominant headline.
//
// SEO copy pass: marketing's new body copy re-opens with the same "1%"
// stat as its first sentence, so the standalone lead-in paragraph (which
// said the same thing above the headline) was dropped to avoid repeating
// it twice back to back — an interpretation call, not an explicit
// instruction; see CLAUDE.md.
const facts = [
  { value: '20', label: 'River-Touching Villa Plots' },
  { value: 'OC Applied', label: 'Status' },
  { value: 'Private', label: 'River Access & Views' },
];
---

<section class="section section--forest-deep" id="overview">
  <div class="section-inner" style="text-align: center;">
    <p class="eyebrow reveal">Riviera Overview</p>
    <h2 class="section-title reveal reveal-delay-1 overview-headline">
      20 Exclusive River-Touching Villa Plots in Sindhudurg. That's All There
      Ever Will Be.
    </h2>
    <p class="section-body reveal reveal-delay-2 overview-body">
      Only <em>1%</em> of India's land is riverfront. Rivers belong to
      everyone — riverfront doesn't. Shoreline is finite, coastal regulations
      are tighter each year, and no one is creating more riverfront land.
      These 20 residential plots in Vagade, Sindhudurg are among the last
      opportunities to own an uninterrupted stretch of the Gad River, where
      riverside living isn't a view from the balcony — it's your backyard.
    </p>

    <div class="stat-grid overview-facts">
      {
        facts.map((f, i) => (
          <div class={`stat-card overview-fact-card reveal reveal-delay-${Math.min(i + 1, 3)}`}>
            <div class="stat-card__value overview-fact-value">{f.value}</div>
            <div class="stat-card__label overview-fact-label">{f.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* The one dominant headline in this section. */
  .overview-headline {
    margin-top: 0.6rem;
    font-size: clamp(1.6rem, 6.5vw, 2.4rem);
  }

  .overview-body {
    margin-top: 1rem;
    max-width: 46ch;
    margin-left: auto;
    margin-right: auto;
  }

  .overview-body em {
    font-style: normal;
    color: var(--brand-aqua-light);
  }

  /* More room to breathe before the fact strip, and a bigger gap between
     cards so the row doesn't read as cramped on either mobile or desktop.
     Stacked one-per-row on mobile per marketing's spec (not the shared
     2-up .stat-grid default, which would orphan the 3rd card). */
  .overview-facts {
    grid-template-columns: 1fr;
    margin-top: 1.75rem;
    gap: 0.85rem;
  }

  .overview-fact-card {
    padding: 1.15rem 1rem;
  }

  .overview-fact-value {
    font-size: clamp(1.5rem, 7vw, 2.1rem);
  }

  .overview-fact-label {
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    opacity: 0.9;
  }

  @media (min-width: 640px) {
    .overview-facts {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.1rem;
    }

    .overview-fact-card {
      padding: 1.5rem 1.15rem;
    }
  }
</style>
