---
import Placeholder from '../Placeholder.astro';
---

<section class="section section--forest-deep" id="site-plan">
  <div class="section-inner">
    <p class="eyebrow reveal">The Layout</p>
    <h2 class="section-title reveal">Unlock the Site Plan for The Riviera, Vagade</h2>
    <p class="section-body reveal reveal-delay-1">
      Share your details to view the site plan and plot layout for these
      riverfront villa plots in Sindhudurg.
    </p>

    <div class="gate reveal reveal-delay-2">
      <div class="gate__locked-asset">
        <Placeholder label="Site Plan" aspectRatio="1 / 1" />
      </div>
      <div class="gate__unlocked-asset">
        <Placeholder label="Site Plan — unlocked" aspectRatio="1 / 1" />
      </div>
      <div class="gate__overlay">
        <div class="gate__icon">&#128274;</div>
        <p style="font-weight: 700; font-size: 0.9rem;">Unlock the Site Plan</p>
        <div class="gate__actions">
          <button type="button" class="btn btn-primary" data-gate-trigger data-intent="siteplan">
            View Site Plan
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gate__locked-asset {
    padding: 0.9rem;
    max-width: 320px;
    margin: 0 auto;
  }

  .gate.is-unlocked .gate__unlocked-asset {
    display: block;
    padding: 0.9rem;
    max-width: 320px;
    margin: 0 auto;
  }

  /* The overlay must stay above the locked asset and remain clickable at
     every viewport width — explicit here rather than relying on DOM order
     alone, since a desktop click-doesn't-work report was traced to this
     section. */
  .gate__overlay {
    z-index: 1;
    pointer-events: auto;
  }

  .gate__actions button {
    pointer-events: auto;
  }
</style>
