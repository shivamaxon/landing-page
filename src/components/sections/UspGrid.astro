---
const usps = [
  {
    value: '20',
    label: 'River-touching villa plots',
    desc: 'A hard inventory cap — each plot with uninterrupted river access and panoramic views.',
  },
  {
    value: 'Freehold',
    label: 'Clear title, ready to build',
    desc: 'Development-ready infrastructure. Own and build at your own pace.',
  },
  {
    value: 'Private',
    label: 'River access & views',
    desc: 'Unobstructed river views from every plot, with private access to the water.',
  },
];
---

<section class="section section--cream">
  <div class="section-inner">
    <p class="eyebrow reveal">The Offer</p>
    <h2 class="section-title reveal">20 River-Touching Plots. That's All There Ever Will Be.</h2>
    <div class="stat-grid">
      {
        usps.map((u, i) => (
          <div
            class:list={[
              'stat-card',
              'reveal',
              `reveal-delay-${Math.min(i + 1, 3)}`,
              { 'span-all': i === usps.length - 1 && usps.length % 2 !== 0 },
            ]}
          >
            <div class="stat-card__value">{u.value}</div>
            <div class="stat-card__label">{u.label}</div>
            <div class="stat-card__desc">{u.desc}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
