---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StickyCta from '../components/StickyCta.astro';
import QuickContactStack from '../components/QuickContactStack.astro';
import LeadModal from '../components/LeadModal.astro';
import Lightbox from '../components/Lightbox.astro';
import Hero from '../components/sections/Hero.astro';
import RivieraOverview from '../components/sections/RivieraOverview.astro';
import LocationConnectivity from '../components/sections/LocationConnectivity.astro';
import LifestyleDetail from '../components/sections/LifestyleDetail.astro';
import LifestyleGallery from '../components/sections/LifestyleGallery.astro';
import GrowthThesis from '../components/sections/GrowthThesis.astro';
import SitePlanGated from '../components/sections/SitePlanGated.astro';
import AboutDeveloper from '../components/sections/AboutDeveloper.astro';
import BookSiteVisit from '../components/sections/BookSiteVisit.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import Faq from '../components/sections/Faq.astro';
import Footer from '../components/sections/Footer.astro';

// Derived entirely from on-page content — no fields invented beyond what's
// already stated elsewhere on the page (see CLAUDE.md §11 for the pricing/
// approval-status figures that are deliberately NOT included here).
const realEstateJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateListing',
  name: 'The Riviera by Axon Developers',
  description:
    '20 river-touching villa plots on the Gad River in Vagade, Sindhudurg, Konkan.',
  url: new URL(Astro.url.pathname, Astro.url.origin).href,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Vagade',
    addressRegion: 'Sindhudurg, Maharashtra',
    addressCountry: 'IN',
  },
  provider: {
    '@type': 'Organization',
    name: 'Axon Developers',
  },
};
---

<Layout
  ogTitle="The Riviera by Axon Developers | Riverfront Villa Plots in Sindhudurg"
  ogDescription="20 river-touching residential plots in Vagade, Sindhudurg. Rare riverfront living on the Gad River, NH-66, minutes from Goa."
>
  <Header />
  <Hero />
  <RivieraOverview />
  <LocationConnectivity />
  <LifestyleDetail />
  <LifestyleGallery />
  <GrowthThesis />
  <SitePlanGated />
  <AboutDeveloper />
  <BookSiteVisit />
  <FinalCta />
  <Faq />
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(realEstateJsonLd)} />
  <StickyCta />
  <QuickContactStack />
  <LeadModal />
  <Lightbox />

  <script>
    import '../scripts/reveal.js';
    import '../scripts/lightbox.js';
    import '../scripts/carousel.js';
    import '../scripts/gating.js';
  </script>
</Layout>
